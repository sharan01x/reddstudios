---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
const posts = await getCollection('posts');
const audioArticles = articles.filter(a => a.data.audio);
const podcastArticles = articles.filter(a => a.data.podcast);

// Extract YouTube videos from articles
const videoArticles = articles
  .filter(article => {
    const content = article.body;
    return content.includes('youtube.com') || content.includes('youtu.be');
  })
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const allTags = [...new Set(posts.flatMap(p => p.data.tags))].sort();
const articleTags = [...new Set(articles.flatMap(a => a.data.tags))].sort();

const formatDate = (dateStr: string) => {
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' });
};

// Extract YouTube video IDs from content
const extractYouTubeVideos = (content: string) => {
  const youtubeRegex = /(?:https?:\/\/)?(?:www\.)?(?:youtube\.com\/(?:[^\/\n\s]+\/\S+\/|(?:v|e(?:mbed)?)\/|\S*?[?&]v=)|youtu\.be\/)([a-zA-Z0-9_-]{11})/g;
  const matches = [];
  let match;
  while ((match = youtubeRegex.exec(content)) !== null) {
    matches.push(match[1]);
  }
  return matches;
};
---

<BaseLayout title="Redd XF">
    <div class="container">
        <div class="header">
            <h1>Redd XF</h1>
            <div class="subtitle">Building startups, pushing pixels, slicing videos, compiling code or writing verse.</div>
            <div style="margin-top: 20px;">
                <a href="https://reddxf.substack.com" class="rss-link" target="_blank" rel="noopener">
                    <i class="fas fa-envelope"></i> Subscribe
                </a>
                <a href="/rss.xml" class="rss-link" style="margin-left: 15px;">
                    <i class="fas fa-rss"></i> RSS
                </a>
            </div>
        </div>
        
        <!-- Tabs Navigation -->
        <div class="tabs-container">
            <div class="tabs-nav">
                <button class="tab-button active" data-tab="posts"><i class="fas fa-comment-dots"></i>Posts</button>
                <button class="tab-button" data-tab="articles"><i class="fas fa-newspaper"></i>Articles</button>
                <button class="tab-button" data-tab="audio"><i class="fas fa-headphones"></i>Audio</button>
                <button class="tab-button" data-tab="podcasts"><i class="fas fa-podcast"></i>Podcasts</button>
                <button class="tab-button" data-tab="videos"><i class="fas fa-video"></i>Videos</button>
            </div>
        </div>
        
        <!-- Posts Tab Content -->
        <div id="posts-tab" class="tab-content active">
            <div class="tags-cloud">
                <button class="tag-filter active" data-tag="all">All</button>
                {allTags.map(tag => (
                    <button class="tag-filter" data-tag={tag}>#{tag}</button>
                ))}
            </div>
            <div class="posts-grid">
                {posts.map((post, index) => (
                    <div class="post-card" data-tags={post.data.tags.join(' ')}>
                        {post.data.image && (
                            <div class="post-image">
                                <img src={post.data.image} alt="" loading="lazy">
                            </div>
                        )}
                        <div class="post-body">
                            <div class={`post-content ${!post.data.image ? 'post-content--no-image' : ''} ${post.body.length < 200 ? 'post-content--short' : ''}`}>
                                {post.body}
                            </div>
                            <div class="post-meta">
                                <span class="post-date">{formatDate(post.data.date)}</span>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
        
        <!-- Articles Tab Content -->
        <div id="articles-tab" class="tab-content">
            <div class="tags-cloud" id="articles-tags-cloud">
                <button class="tag-filter active" data-tag="all" data-scope="articles">All</button>
                {articleTags.map(tag => (
                    <button class="tag-filter" data-tag={tag} data-scope="articles">{tag}</button>
                ))}
            </div>
            <div class="articles-list">
                {articles.map((article) => (
                    <div class="article-item" data-tags={article.data.tags.join(' ')}>
                        <div class="article-header">
                            <h2><a href={`/articles/${article.slug}`}>{article.data.title}</a></h2>
                            <div class="article-subtitle">{article.data.subtitle}</div>
                        </div>
                        <div class="article-meta">
                            <span class="article-date">{formatDate(article.data.date)}</span>
                            <span class="article-author">by {article.data.author}</span>
                        </div>
                        <div class="article-tags">
                            {article.data.tags.map(tag => (
                                <span class="tag">{tag}</span>
                            ))}
                        </div>
                    </div>
                ))}
            </div>
        </div>
        
        <!-- Audio Tab Content -->
        <div id="audio-tab" class="tab-content">
            <div class="playlist-container">
                {audioArticles.map((article, index) => (
                    <div class="playlist-item" data-index={index}>
                        <div class="playlist-number">{index + 1}</div>
                        <div class="playlist-info">
                            <div class="playlist-title">{article.data.title}</div>
                            <div class="playlist-subtitle">{article.data.subtitle}</div>
                            <div class="playlist-meta">
                                <span class="playlist-author">{article.data.author}</span>
                                <span class="playlist-date">{formatDate(article.data.date)}</span>
                            </div>
                            <div class="playlist-tags">
                                {article.data.tags.map(tag => (
                                    <span class="tag">{tag}</span>
                                ))}
                            </div>
                        </div>
                        <div class="playlist-player">
                            <audio class="audio-player" data-index={index} controls preload="none">
                                <source src={article.data.audio} type="audio/mpeg">
                            </audio>
                        </div>
                    </div>
                ))}
            </div>
        </div>
        
        <!-- Podcasts Tab Content -->
        <div id="podcasts-tab" class="tab-content">
            <div class="playlist-container">
                {podcastArticles.map((article, index) => (
                    <div class="playlist-item podcast" data-index={index}>
                        <div class="podcast-artwork-container">
                            <div class="podcast-artwork-placeholder"></div>
                        </div>
                        <div class="playlist-info">
                            <div class="podcast-episode-badge">S1E{index + 1}</div>
                            <div class="playlist-title">{article.data.title}</div>
                            <div class="playlist-subtitle">{article.data.subtitle}</div>
                            <div class="playlist-meta">
                                <span class="playlist-author">{article.data.author}</span>
                                <span class="playlist-date">{formatDate(article.data.date)}</span>
                            </div>
                            <div class="playlist-tags">
                                {article.data.tags.map(tag => (
                                    <span class="tag">{tag}</span>
                                ))}
                            </div>
                        </div>
                        <div class="playlist-player">
                            <audio class="podcast-player" data-index={index} controls preload="none">
                                <source src={article.data.podcast} type="audio/mpeg">
                            </audio>
                        </div>
                    </div>
                ))}
            </div>
        </div>
        
        <!-- Videos Tab Content -->
        <div id="videos-tab" class="tab-content">
            <div class="playlist-container">
                {videoArticles.map((article, index) => {
                    const videoIds = extractYouTubeVideos(article.body);
                    return (
                        <div class="playlist-item video" data-index={index}>
                            <div class="playlist-info">
                                <div class="playlist-title">{article.data.title}</div>
                                <div class="playlist-subtitle">{article.data.subtitle}</div>
                                <div class="playlist-meta">
                                    <span class="playlist-author">{article.data.author}</span>
                                    <span class="playlist-date">{formatDate(article.data.date)}</span>
                                </div>
                                <div class="playlist-tags">
                                    {article.data.tags.map(tag => (
                                        <span class="tag">{tag}</span>
                                    ))}
                                </div>
                            </div>
                            <div class="playlist-player">
                                <div class="video-thumbnails">
                                    {videoIds.map(videoId => (
                                        <a 
                                            href={`https://www.youtube.com/watch?v=${videoId}`} 
                                            target="_blank" 
                                            rel="noopener noreferrer"
                                            class="video-thumbnail"
                                        >
                                            <img 
                                                src={`https://img.youtube.com/vi/${videoId}/mqdefault.jpg`} 
                                                alt="YouTube video thumbnail"
                                                loading="lazy"
                                            />
                                            <div class="video-play-icon">
                                                <i class="fas fa-play"></i>
                                            </div>
                                        </a>
                                    ))}
                                </div>
                            </div>
                        </div>
                    );
                })}
            </div>
        </div>
    </div>
</BaseLayout>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const tabButtons = document.querySelectorAll('.tab-button');
        const tabContents = document.querySelectorAll('.tab-content');
        
        tabButtons.forEach(button => {
            button.addEventListener('click', () => {
                const tab = button.dataset.tab;
                
                tabButtons.forEach(b => b.classList.remove('active'));
                tabContents.forEach(c => c.classList.remove('active'));
                
                button.classList.add('active');
                document.getElementById(`${tab}-tab`)?.classList.add('active');
            });
        });
        
        const tagFilters = document.querySelectorAll('.tag-filter');
        
        tagFilters.forEach(filter => {
            filter.addEventListener('click', () => {
                const tag = filter.dataset.tag;
                const scope = filter.dataset.scope || 'posts';
                const container = scope === 'articles' ? '.articles-list' : '.posts-grid';
                const items = document.querySelectorAll(`${container} > *`);
                const cloud = filter.closest('.tags-cloud');
                const filters = cloud?.querySelectorAll('.tag-filter');
                
                filters?.forEach(f => f.classList.remove('active'));
                filter.classList.add('active');
                
                items.forEach(item => {
                    if (tag === 'all') {
                        item.classList.remove('hidden-by-filter');
                    } else {
                        const tags = item.dataset.tags || '';
                        if (tags.toLowerCase().includes(tag.toLowerCase())) {
                            item.classList.remove('hidden-by-filter');
                        } else {
                            item.classList.add('hidden-by-filter');
                        }
                    }
                });
            });
        });
        
        // Audio playlist functionality
        (function() {
            const DELAY_BETWEEN_TRACKS = 5000;
            
            const audioPlayers = document.querySelectorAll('.audio-player');
            const podcastPlayers = document.querySelectorAll('.podcast-player');
            const audioItems = document.querySelectorAll('#audio-tab .playlist-item');
            const podcastItems = document.querySelectorAll('#podcasts-tab .playlist-item');
            
            audioPlayers.forEach((player, index) => {
                player.addEventListener('play', () => {
                    audioPlayers.forEach((p, i) => {
                        if (i !== index) p.pause();
                    });
                    podcastPlayers.forEach(p => p.pause());
                    
                    audioItems.forEach((item, i) => {
                        item.classList.toggle('playing', i === index);
                    });
                    podcastItems.forEach(item => {
                        item.classList.remove('playing');
                    });
                });
                
                player.addEventListener('ended', () => {
                    audioItems[index]?.classList.remove('playing');
                    
                    const nextIndex = index + 1;
                    if (nextIndex < audioPlayers.length) {
                        setTimeout(() => {
                            audioPlayers[nextIndex].play();
                        }, DELAY_BETWEEN_TRACKS);
                    }
                });
                
                player.addEventListener('pause', () => {
                    if (!player.ended) {
                        audioItems[index]?.classList.remove('playing');
                    }
                });
            });
            
            podcastPlayers.forEach((player, index) => {
                player.addEventListener('play', () => {
                    podcastPlayers.forEach((p, i) => {
                        if (i !== index) p.pause();
                    });
                    audioPlayers.forEach(p => p.pause());
                    
                    podcastItems.forEach((item, i) => {
                        item.classList.toggle('playing', i === index);
                    });
                    audioItems.forEach(item => {
                        item.classList.remove('playing');
                    });
                });
                
                player.addEventListener('ended', () => {
                    podcastItems[index]?.classList.remove('playing');
                    
                    const nextIndex = index + 1;
                    if (nextIndex < podcastPlayers.length) {
                        setTimeout(() => {
                            podcastPlayers[nextIndex].play();
                        }, DELAY_BETWEEN_TRACKS);
                    }
                });
                
                player.addEventListener('pause', () => {
                    if (!player.ended) {
                        podcastItems[index]?.classList.remove('playing');
                    }
                });
            });
        })();
    });
</script>
