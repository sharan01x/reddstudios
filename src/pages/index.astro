---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles').then(articles => 
  articles.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
);
const posts = await getCollection('posts');
const audioArticles = articles.filter(a => a.data.audio);
const podcastArticles = articles.filter(a => a.data.podcast);

// Extract YouTube videos from articles
const videoArticles = articles
  .filter(article => {
    const content = article.body;
    return content.includes('youtube.com') || content.includes('youtu.be');
  })
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Additional videos from user-provided list
const additionalVideos = [
  {
    title: "8 Crucial Insights from Building an AI-Infused App",
    subtitle: "Discover the critical lessons gained from developing a cutting-edge application in the evolving landscape of programming",
    date: "04 Aug 2025",
    author: "sharanx",
    tags: ["ai", "design", "technology"],
    videoId: "HcqI67Ij8sc"
  },
  {
    title: "How to go from designing UX in Web2 to Web3",
    subtitle: "Understanding the transition from traditional web design to decentralized web experiences",
    date: "01 Aug 2025",
    author: "sharanx",
    tags: ["ux", "web3", "design"],
    videoId: "u_cEEB6D2Q8"
  },
  {
    title: "Review of Replit, the Figma Killer",
    subtitle: "Replit has been thought of as a tool that will replace Figma. I tested it out to see if that is true.",
    date: "31 Jul 2025",
    author: "sharanx",
    tags: ["design", "ux", "ai", "tools", "technology"],
    videoId: "EPCrwNTKr5s"
  },
  {
    title: "Five personal AI assistant devices reviewed and what they need to fix",
    subtitle: "The world of AI assistants has taken a sharp leap forward with new devices emerging every year. However, despite the excitement around these personal AI assistant devices, many haven't lived up to their full potential.",
    date: "12 Sept 2024",
    author: "sharanx",
    tags: ["product", "hardware", "design", "technology"],
    videoId: "7GPtfH1lYkI"
  },
  {
    title: "The Ultimate Guide to Hiring the Right UX Design Agency",
    subtitle: "It doesn't matter that the design agency has a high rating if they aren't a good fit for your project. But how do you find the right one?",
    date: "15 Nov 2024",
    author: "sharanx",
    tags: ["design", "business"],
    videoId: "pWzm4IwFXZI"
  },
  {
    title: "Designing Web3 Wallets for Mainstream Users",
    subtitle: "There is a problem with Web3 wallets, they're just too complex. But where's the problem stemming from and how do we solve it?",
    date: "30 Sept 2024",
    author: "sharanx",
    tags: ["design"],
    videoId: "flGWL54hJR4"
  },
  {
    title: "The New Age of the Design Generalist",
    subtitle: "Exploring the evolving role of designers who can work across multiple disciplines",
    date: "01 Jan 2025",
    author: "sharanx",
    tags: ["design", "ux", "product"],
    videoId: "uQgPwASdn5U"
  }
].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const allTags = [...new Set(posts.flatMap(p => p.data.tags))].sort();
const articleTags = [...new Set(articles.flatMap(a => a.data.tags))].sort();

const formatDate = (dateStr: string) => {
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' });
};

// Extract YouTube video IDs from content
const extractYouTubeVideos = (content: string) => {
  const youtubeRegex = /(?:https?:\/\/)?(?:www\.)?(?:youtube\.com\/(?:[^\/\n\s]+\/\S+\/|(?:v|e(?:mbed)?)\/|\S*?[?&]v=)|youtu\.be\/)([a-zA-Z0-9_-]{11})/g;
  const matches = [];
  let match;
  while ((match = youtubeRegex.exec(content)) !== null) {
    matches.push(match[1]);
  }
  return matches;
};
---

<BaseLayout title="Redd XF">
    <div class="container">
        <div class="header">
            <h1>Redd XF</h1>
            <div class="subtitle">Building startups, pushing pixels, slicing videos, compiling code or writing verse.</div>
            <div style="margin-top: 20px;">
                <a href="https://reddxf.substack.com" class="rss-link" target="_blank" rel="noopener">
                    <i class="fas fa-envelope"></i> Subscribe
                </a>
                <a href="/rss.xml" class="rss-link" style="margin-left: 15px;">
                    <i class="fas fa-rss"></i> RSS
                </a>
            </div>
        </div>
        
        <!-- Tabs Navigation -->
        <div class="tabs-container">
            <div class="tabs-nav">
                <button class="tab-button active" data-tab="posts"><i class="fas fa-comment-dots"></i>Posts</button>
                <button class="tab-button" data-tab="articles"><i class="fas fa-newspaper"></i>Articles</button>
                <button class="tab-button" data-tab="audio"><i class="fas fa-headphones"></i>Audio</button>
                <button class="tab-button" data-tab="podcasts"><i class="fas fa-podcast"></i>Podcasts</button>
                <button class="tab-button" data-tab="videos"><i class="fas fa-video"></i>Videos</button>
            </div>
        </div>
        
        <!-- Posts Tab Content -->
        <div id="posts-tab" class="tab-content active">
            <div class="tags-cloud">
                <button class="tag-filter active" data-tag="all">All</button>
                {allTags.map(tag => (
                    <button class="tag-filter" data-tag={tag}>#{tag}</button>
                ))}
            </div>
            <div class="posts-grid">
                {posts.map((post, index) => (
                    <div class="post-card" data-tags={post.data.tags.join(' ')}>
                        {post.data.image && (
                            <div class="post-image">
                                <img src={post.data.image} alt="" loading="lazy">
                            </div>
                        )}
                        <div class="post-body">
                            <div class={`post-content ${!post.data.image ? 'post-content--no-image' : ''} ${post.body.length < 200 ? 'post-content--short' : ''}`}>
                                {post.body}
                            </div>
                            <div class="post-meta">
                                <span class="post-date">{formatDate(post.data.date)}</span>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
        
        <!-- Articles Tab Content -->
        <div id="articles-tab" class="tab-content">
            <div class="tags-cloud" id="articles-tags-cloud">
                <button class="tag-filter active" data-tag="all" data-scope="articles">All</button>
                {articleTags.map(tag => (
                    <button class="tag-filter" data-tag={tag} data-scope="articles">{tag}</button>
                ))}
            </div>
            <div class="articles-list">
                {articles.map((article) => (
                    <div class="article-item" data-tags={article.data.tags.join(' ')}>
                        <div class="article-header">
                            <h2><a href={`/articles/${article.slug}`}>{article.data.title}</a></h2>
                            <div class="article-subtitle">{article.data.subtitle}</div>
                        </div>
                        <div class="article-meta">
                            <span class="article-date">{formatDate(article.data.date)}</span>
                            <span class="article-author">by {article.data.author}</span>
                        </div>
                        <div class="article-tags">
                            {article.data.tags.map(tag => (
                                <span class="tag">{tag}</span>
                            ))}
                        </div>
                    </div>
                ))}
            </div>
        </div>
        
        <!-- Audio Tab Content -->
        <div id="audio-tab" class="tab-content">
            <div class="playlist-container">
                {audioArticles.map((article, index) => (
                    <div class="playlist-item" data-index={index}>
                        <div class="playlist-number">{index + 1}</div>
                        <div class="playlist-info">
                            <div class="playlist-title">{article.data.title}</div>
                            <div class="playlist-subtitle">{article.data.subtitle}</div>
                            <div class="playlist-meta">
                                <span class="playlist-author">{article.data.author}</span>
                                <span class="playlist-date">{formatDate(article.data.date)}</span>
                            </div>
                            <div class="playlist-tags">
                                {article.data.tags.map(tag => (
                                    <span class="tag">{tag}</span>
                                ))}
                            </div>
                        </div>
                        <div class="playlist-player">
                            <audio class="audio-player" data-index={index} controls preload="none">
                                <source src={article.data.audio} type="audio/mpeg">
                            </audio>
                        </div>
                    </div>
                ))}
            </div>
        </div>
        
        <!-- Podcasts Tab Content -->
        <div id="podcasts-tab" class="tab-content">
            <div class="playlist-container">
                {podcastArticles.map((article, index) => (
                    <div class="playlist-item podcast" data-index={index}>
                        <div class="podcast-artwork-container">
                            <div class="podcast-artwork-placeholder"></div>
                        </div>
                        <div class="playlist-info">
                            <div class="podcast-episode-badge">S1E{index + 1}</div>
                            <div class="playlist-title">{article.data.title}</div>
                            <div class="playlist-subtitle">{article.data.subtitle}</div>
                            <div class="playlist-meta">
                                <span class="playlist-author">{article.data.author}</span>
                                <span class="playlist-date">{formatDate(article.data.date)}</span>
                            </div>
                            <div class="playlist-tags">
                                {article.data.tags.map(tag => (
                                    <span class="tag">{tag}</span>
                                ))}
                            </div>
                        </div>
                        <div class="playlist-player">
                            <audio class="podcast-player" data-index={index} controls preload="none">
                                <source src={article.data.podcast} type="audio/mpeg">
                            </audio>
                        </div>
                    </div>
                ))}
            </div>
        </div>
        
        <!-- Videos Tab Content -->
        <div id="videos-tab" class="tab-content">
            <div class="videos-grid">
                {additionalVideos.map((video, index) => (
                    <div class="video-card" data-index={index}>
                        <div class="video-thumbnail-container">
                            <a 
                                href={`https://www.youtube.com/watch?v=${video.videoId}`} 
                                target="_blank" 
                                rel="noopener noreferrer"
                                class="video-thumbnail-link"
                            >
                                <img 
                                    src={`https://img.youtube.com/vi/${video.videoId}/mqdefault.jpg`} 
                                    alt={video.title}
                                    loading="lazy"
                                    class="video-thumbnail"
                                />
                                <div class="video-play-overlay">
                                    <i class="fas fa-play"></i>
                                </div>
                            </a>
                        </div>
                        <div class="video-info">
                            <h3 class="video-title">
                                <a href={`https://www.youtube.com/watch?v=${video.videoId}`} target="_blank" rel="noopener noreferrer">
                                    {video.title}
                                </a>
                            </h3>
                            <p class="video-subtitle">{video.subtitle}</p>
                            <div class="video-meta">
                                <span class="video-author">by {video.author}</span>
                                <span class="video-date">{formatDate(video.date)}</span>
                            </div>
                            <div class="video-tags">
                                {video.tags.map(tag => (
                                    <span class="tag">{tag}</span>
                                ))}
                            </div>
                        </div>
                    </div>
                ))}
                {videoArticles.map((article, index) => {
                    const videoIds = extractYouTubeVideos(article.body);
                    return (
                        <div class="video-card" data-index={index + additionalVideos.length}>
                            <div class="video-thumbnail-container">
                                {videoIds.map(videoId => (
                                    <a 
                                        key={videoId}
                                        href={`https://www.youtube.com/watch?v=${videoId}`} 
                                        target="_blank" 
                                        rel="noopener noreferrer"
                                        class="video-thumbnail-link"
                                    >
                                        <img 
                                            src={`https://img.youtube.com/vi/${videoId}/mqdefault.jpg`} 
                                            alt={article.data.title}
                                            loading="lazy"
                                            class="video-thumbnail"
                                        />
                                        <div class="video-play-overlay">
                                            <i class="fas fa-play"></i>
                                        </div>
                                    </a>
                                ))}
                            </div>
                            <div class="video-info">
                                <h3 class="video-title">
                                    <a href={`/articles/${article.slug}`} target="_blank" rel="noopener noreferrer">
                                        {article.data.title}
                                    </a>
                                </h3>
                                <p class="video-subtitle">{article.data.subtitle}</p>
                                <div class="video-meta">
                                    <span class="video-author">by {article.data.author}</span>
                                    <span class="video-date">{formatDate(article.data.date)}</span>
                                </div>
                                <div class="video-tags">
                                    {article.data.tags.map(tag => (
                                        <span class="tag">{tag}</span>
                                    ))}
                                </div>
                            </div>
                        </div>
                    );
                })}
            </div>
        </div>
    </div>
</BaseLayout>

<script>
    // Function to activate a tab by name
    function activateTab(tabName) {
        const tabButtons = document.querySelectorAll('.tab-button');
        const tabContents = document.querySelectorAll('.tab-content');
        
        tabButtons.forEach(button => {
            button.classList.remove('active');
        });
        tabContents.forEach(content => {
            content.classList.remove('active');
        });
        
        const targetButton = document.querySelector(`.tab-button[data-tab="${tabName}"]`);
        if (targetButton) {
            targetButton.classList.add('active');
        }
        
        const targetContent = document.getElementById(`${tabName}-tab`);
        if (targetContent) {
            targetContent.classList.add('active');
        }
    }
    
    document.addEventListener('DOMContentLoaded', function() {
        const tabButtons = document.querySelectorAll('.tab-button');
        const tabContents = document.querySelectorAll('.tab-content');
        
        tabButtons.forEach(button => {
            button.addEventListener('click', () => {
                const tab = button.dataset.tab;
                
                tabButtons.forEach(b => b.classList.remove('active'));
                tabContents.forEach(c => c.classList.remove('active'));
                
                button.classList.add('active');
                document.getElementById(`${tab}-tab`)?.classList.add('active');
            });
        });
        
        const tagFilters = document.querySelectorAll('.tag-filter');
        
        tagFilters.forEach(filter => {
            filter.addEventListener('click', () => {
                const tag = filter.dataset.tag;
                const scope = filter.dataset.scope || 'posts';
                const container = scope === 'articles' ? '.articles-list' : '.posts-grid';
                const items = document.querySelectorAll(`${container} > *`);
                const cloud = filter.closest('.tags-cloud');
                const filters = cloud?.querySelectorAll('.tag-filter');
                
                filters?.forEach(f => f.classList.remove('active'));
                filter.classList.add('active');
                
                items.forEach(item => {
                    if (tag === 'all') {
                        item.classList.remove('hidden-by-filter');
                    } else {
                        const tags = item.dataset.tags || '';
                        if (tags.toLowerCase().includes(tag.toLowerCase())) {
                            item.classList.remove('hidden-by-filter');
                        } else {
                            item.classList.add('hidden-by-filter');
                        }
                    }
                });
            });
        });
        
        // Audio playlist functionality
        (function() {
            const DELAY_BETWEEN_TRACKS = 5000;
            
            const audioPlayers = document.querySelectorAll('.audio-player');
            const podcastPlayers = document.querySelectorAll('.podcast-player');
            const audioItems = document.querySelectorAll('#audio-tab .playlist-item');
            const podcastItems = document.querySelectorAll('#podcasts-tab .playlist-item');
            
            audioPlayers.forEach((player, index) => {
                player.addEventListener('play', () => {
                    audioPlayers.forEach((p, i) => {
                        if (i !== index) p.pause();
                    });
                    podcastPlayers.forEach(p => p.pause());
                    
                    audioItems.forEach((item, i) => {
                        item.classList.toggle('playing', i === index);
                    });
                    podcastItems.forEach(item => {
                        item.classList.remove('playing');
                    });
                });
                
                player.addEventListener('ended', () => {
                    audioItems[index]?.classList.remove('playing');
                    
                    const nextIndex = index + 1;
                    if (nextIndex < audioPlayers.length) {
                        setTimeout(() => {
                            audioPlayers[nextIndex].play();
                        }, DELAY_BETWEEN_TRACKS);
                    }
                });
                
                player.addEventListener('pause', () => {
                    if (!player.ended) {
                        audioItems[index]?.classList.remove('playing');
                    }
                });
            });
            
            podcastPlayers.forEach((player, index) => {
                player.addEventListener('play', () => {
                    podcastPlayers.forEach((p, i) => {
                        if (i !== index) p.pause();
                    });
                    audioPlayers.forEach(p => p.pause());
                    
                    podcastItems.forEach((item, i) => {
                        item.classList.toggle('playing', i === index);
                    });
                    audioItems.forEach(item => {
                        item.classList.remove('playing');
                    });
                });
                
                player.addEventListener('ended', () => {
                    podcastItems[index]?.classList.remove('playing');
                    
                    const nextIndex = index + 1;
                    if (nextIndex < podcastPlayers.length) {
                        setTimeout(() => {
                            podcastPlayers[nextIndex].play();
                        }, DELAY_BETWEEN_TRACKS);
                    }
                });
                
                player.addEventListener('pause', () => {
                    if (!player.ended) {
                        podcastItems[index]?.classList.remove('playing');
                    }
                });
            });
        })();
        
        // Handle tab activation from URL hash on page load
        function initTabFromHash() {
            const hash = window.location.hash.slice(1); // Remove '#'
            activateTab(hash || 'posts');
        }
        
        // Listen for hash changes (e.g., browser back/forward)
        window.addEventListener('hashchange', () => {
            const hash = window.location.hash.slice(1);
            activateTab(hash || 'posts');
        });
        
        // Initialize on page load
        initTabFromHash();
    });
</script>
